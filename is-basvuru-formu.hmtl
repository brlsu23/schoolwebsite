<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>İş Başvuru Formu | DataKent Koleji</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary: #1a2a6c;
            --secondary: #b21f1f;
            --accent: #fdbb2d;
            --bg: #f4f7f6;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 40px 20px;
        }

        .form-card {
            max-width: 850px;
            margin: 0 auto;
            background: #fff;
            border-radius: 25px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .form-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            padding: 50px 30px;
            text-align: center;
        }

        .form-header h2 {
            margin: 0;
            font-size: 2rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .form-body { padding: 40px; }

        /* Bölüm Tasarımları */
        .step-container { margin-bottom: 40px; position: relative; }

        .step-title {
            display: flex;
            align-items: center;
            font-size: 1.2rem;
            color: var(--primary);
            font-weight: 700;
            margin-bottom: 25px;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }

        .step-title i {
            width: 40px;
            height: 40px;
            background: var(--accent);
            color: var(--primary);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 1.1rem;
        }

        /* Input Düzeni */
        .input-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .input-group { display: flex; flex-direction: column; margin-bottom: 15px; }

        label {
            font-size: 0.9rem;
            font-weight: 600;
            color: #444;
            margin-bottom: 8px;
        }

        input, select, textarea {
            padding: 14px;
            border: 2px solid #f0f0f0;
            border-radius: 12px;
            font-family: inherit;
            transition: 0.3s;
            background: #fafafa;
        }

        input:focus, select:focus, textarea:focus {
            border-color: var(--primary);
            background: #fff;
            outline: none;
            box-shadow: 0 5px 15px rgba(26, 42, 108, 0.05);
        }

        /* Radio & Checkbox */
        .option-group { display: flex; gap: 20px; margin-top: 5px; }
        .option-item { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.95rem; }

        /* Dosya Yükleme Alanı */
        .upload-area {
            border: 2px dashed #ddd;
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
            background: #fdfdfd;
        }

        .upload-area:hover { border-color: var(--secondary); background: #fff5f5; }

        /* Gönder Butonu */
        .submit-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 18px;
            width: 100%;
            border-radius: 15px;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            transition: 0.4s;
            margin-top: 20px;
            box-shadow: 0 10px 20px rgba(26, 42, 108, 0.2);
        }

        .submit-btn:hover {
            background: var(--secondary);
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(178, 31, 31, 0.3);
        }

        @media (max-width: 600px) {
            .form-body { padding: 20px; }
            .form-header { padding: 30px 15px; }
        }
    </style>
</head>
<body>

<div class="form-card">
    <div class="form-header">
        <img src="data-kent-logo.png" alt="Logo" style="width: 80px; margin-bottom: 15px;">
        <h2>İş Başvuru Formu</h2>
        <p>Datakent Ailesine Katılmak İçin Formu Doldurunuz</p>
    </div>

    <form action="mailto:kecioren.bilgi@datakentegitimkurumlari.com" method="post" enctype="text/plain" class="form-body">
        
        <div class="step-container">
            <div class="step-title"><i class="fas fa-user-tie"></i> Kişisel Bilgiler</div>
            <div class="input-grid">
                <div class="input-group">
                    <label>Ad Soyad</label>
                    <input type="text" name="Ad_Soyad" placeholder="Tam adınızı giriniz" required>
                </div>
                <div class="input-group">
                    <label>E-posta</label>
                    <input type="email" name="Eposta" placeholder="örnek@mail.com" required>
                </div>
                <div class="input-group">
                    <label>Telefon</label>
                    <input type="tel" name="Telefon" placeholder="05XX XXX XX XX" required>
                </div>
                <div class="input-group">
                    <label>Medeni Durum</label>
                    <div class="option-group">
                        <label class="option-item"><input type="radio" name="Medeni_Durum" value="Evli"> Evli</label>
                        <label class="option-item"><input type="radio" name="Medeni_Durum" value="Bekar"> Bekar</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="step-container">
            <div class="step-title"><i class="fas fa-graduation-cap"></i> Eğitim Bilgileri</div>
            <div class="input-grid">
                <div class="input-group" style="grid-column: 1 / -1;">
                    <label>Mezun Olunan Üniversite ve Bölüm</label>
                    <input type="text" name="Egitim" placeholder="Örn: Ankara Üniversitesi - Sınıf Öğretmenliği">
                </div>
                <div class="input-group">
                    <label>Pedagojik Formasyon</label>
                    <div class="option-group">
                        <label class="option-item"><input type="radio" name="Formasyon" value="Var"> Var</label>
                        <label class="option-item"><input type="radio" name="Formasyon" value="Yok"> Yok</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="step-container">
            <div class="step-title"><i class="fas fa-briefcase"></i> Başvurulan Pozisyon</div>
            <div class="input-grid">
                <div class="input-group">
                    <label>Branş Seçimi</label>
                    <select name="Pozisyon" required>
                        <option value="">Seçiniz</option>
                        <option value="Okul Öncesi">Okul Öncesi Öğretmeni</option>
                        <option value="Sınıf">Sınıf Öğretmeni</option>
                        <option value="Matematik">Branş Öğretmeni</option>
                        <option value="Rehberlik">Rehberlik / PDR</option>
                        <option value="İdari">İdari Kadro</option>
                        <option value="Diğer">Diğer</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>Branş Detayı / Ek Not</label>
                    <input type="text" name="Brans_Detay" placeholder="Örn: İngilizce Öğretmeni">
                </div>
            </div>
        </div>

        <div class="step-container">
            <div class="step-title"><i class="fas fa-file-alt"></i> Referanslar & CV</div>
            <div class="input-group">
                <label>Referans Bilgileri</label>
                <textarea name="Referanslar" rows="3" placeholder="Ad Soyad - İletişim"></textarea>
            </div>
            
            <label>Özgeçmiş (CV) Yükleme Alanı</label>
            <div class="upload-area">
                <i class="fas fa-cloud-upload-alt" style="font-size: 2rem; color: var(--secondary); margin-bottom: 10px;"></i>
                <p style="margin: 0; font-size: 0.9rem; color: #666;">CV dosyanızı buraya sürükleyin veya seçin</p>
                <input type="file" name="CV_Dosya" style="margin-top: 10px;">
            </div>
        </div>

        <button type="submit" class="submit-btn">BAŞVURUYU TAMAMLA</button>
        <p style="text-align: center; color: #888; font-size: 0.8rem; margin-top: 15px;">
            * Gönder butonuna bastığınızda e-posta uygulamanız açılacaktır.
        </p>
    </form>
</div>

</body>
</html>
